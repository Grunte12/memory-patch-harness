{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/memory-patch-harness/hot-context-pack.schema.json",
  "title": "Hot Context Pack",
  "type": "object",
  "required": ["role", "canonical_memory", "generated_at", "derived_from", "entries"],
  "properties": {
    "role": { "const": "hot-context-pack" },
    "canonical_memory": { "const": false },
    "generated_at": { "type": "string", "minLength": 4 },
    "derived_from": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence" }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "items": {
        "type": "object",
        "required": ["id", "category", "priority", "confidence", "summary", "source_paths", "lifecycle"],
        "properties": {
          "id": { "type": "string", "minLength": 2 },
          "category": {
            "enum": ["policy", "preference", "workflow", "routing", "gotcha", "stale-warning", "open-question"]
          },
          "priority": { "enum": ["high", "medium", "low"] },
          "confidence": { "enum": ["high", "medium", "low"] },
          "summary": { "type": "string", "minLength": 12 },
          "source_paths": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": { "type": "string", "minLength": 2 }
          },
          "lifecycle": { "$ref": "#/$defs/lifecycle" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": { "enum": ["user-statement", "file", "command", "artifact", "url"] },
        "value": { "type": "string", "minLength": 2 }
      },
      "additionalProperties": true
    },
    "lifecycle": {
      "type": "object",
      "required": ["status", "revalidate_when"],
      "properties": {
        "status": { "enum": ["active", "superseded", "tension", "deprecated"] },
        "valid_until": { "type": "string" },
        "revalidate_when": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 }
        },
        "supersedes": {
          "type": "array",
          "items": { "type": "string", "minLength": 2 }
        }
      },
      "additionalProperties": false
    }
  }
}
