{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/memory-patch-harness/derived-index.schema.json",
  "title": "Derived Index",
  "type": "object",
  "required": ["role", "canonical_memory", "generated_at", "generator", "scope", "derived_from", "entries"],
  "properties": {
    "role": { "const": "derived-index" },
    "canonical_memory": { "const": false },
    "generated_at": { "type": "string", "minLength": 4 },
    "generator": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 2 },
        "version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "scope": {
      "type": "object",
      "required": ["includes"],
      "properties": {
        "includes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "excludes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "derived_from": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence" }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "label", "confidence", "evidence_refs"],
        "properties": {
          "id": { "type": "string", "minLength": 2 },
          "kind": { "enum": ["artifact", "concept", "file", "note", "relation", "symbol"] },
          "label": { "type": "string", "minLength": 2 },
          "confidence": { "enum": ["high", "medium", "low"] },
          "canonical_memory": { "not": { "const": true } },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/evidence" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": { "enum": ["user-statement", "file", "command", "artifact", "url"] },
        "value": { "type": "string", "minLength": 2 }
      },
      "additionalProperties": true
    }
  }
}
