{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Grunte12/memory-patch-harness/main/schemas/memory-patch.schema.json",
  "title": "Memory Patch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim",
    "why_it_matters",
    "scope",
    "provenance",
    "confidence",
    "suggested_type",
    "lifecycle"
  ],
  "properties": {
    "claim": {
      "type": "string",
      "minLength": 12
    },
    "why_it_matters": {
      "type": "string",
      "minLength": 12
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applies", "excludes"],
      "properties": {
        "applies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "excludes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "value"],
        "properties": {
          "kind": {
            "enum": ["user-statement", "file", "command", "artifact", "url"]
          },
          "value": {
            "type": "string",
            "minLength": 2
          }
        }
      }
    },
    "confidence": {
      "enum": ["high", "medium", "low"]
    },
    "suggested_type": {
      "enum": [
        "decision",
        "root-cause",
        "workflow",
        "preference",
        "source-map",
        "tension"
      ]
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "revalidate_when"],
      "properties": {
        "status": {
          "enum": ["active", "superseded", "tension", "deprecated"]
        },
        "valid_until": {
          "type": "string"
        },
        "revalidate_when": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2
          }
        }
      }
    }
  }
}
